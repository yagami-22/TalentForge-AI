generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CANDIDATE
  RECRUITER
}

model User {
  id       String    @id @default(cuid())
  clerkId  String    @unique
  email    String    @unique
  name     String?
  imageUrl String?
  role     UserRole?

  resumes Resume[]
  jobs    Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Resume {
  id               String  @id @default(cuid())
  title            String
  fileUrl          String?
  fileHash         String?
  extractedText    String? @db.Text
  extractionSource String?
  atsScore         Int?
  atsAnalysis      Json?
  atsIssues        Json?
  atsSuggestions   Json?
  matchScore       Int?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, fileHash])
}

model ResumeVersion {
  id             String   @id @default(cuid())
  resumeId       String
  resume         Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  versionNumber  Int
  sourceType     String
  atsScore       Int?
  jobMatchScore  Int?
  addedKeywords  Json?
  removedKeywords Json?
  content        String   @db.Text
  createdAt      DateTime @default(now())

  @@unique([resumeId, versionNumber])
  @@index([resumeId, createdAt])
}

model Job {
  id          String @id @default(cuid())
  title       String
  company     String
  description String @db.Text

  recruiterId String
  recruiter   User   @relation(fields: [recruiterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
